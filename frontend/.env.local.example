# Copy this file to .env.local (gitignored) and adjust if the backend
# isn't running on its default uvicorn address.
#
# Must be running (for both `npm run dev` and `npm run generate-types`)
# for anything in this app to work -- see lib/env.ts and lib/api-client.ts.
#
# Phase 13: MUST be "localhost", not "127.0.0.1", even though both reach
# the same backend -- the auth cookie is SameSite=Lax, and browsers treat
# "localhost" and "127.0.0.1" as different sites for cookie purposes.
# This app is served from http://localhost:3000, so the API origin has to
# be "localhost" too or the cookie set by /auth/register|login is never
# sent back on later requests (found and fixed via a real end-to-end
# browser test, not assumed).
NEXT_PUBLIC_API_URL=http://localhost:8000
